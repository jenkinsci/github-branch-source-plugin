<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:st="jelly:stapler" xmlns:d="jelly:define" xmlns:l="/lib/layout" xmlns:t="/lib/hudson" xmlns:f="/lib/form">
    <f:section title="GitHub API usage">
        <f:entry title="${%Github API usage rate limiting strategy}" field="apiRateLimitChecker">
            <f:select />
        </f:entry>
    </f:section>
    <f:section title="${%Tag Discovery}">
        <f:optionalBlock title="${%Scan tags in descending order}" field="tagDescendingOrder" inline="true">
            <f:entry title="${%Maximum number of tags to process}" field="maxTagCount">
                <f:number default="0" min="0"/>
            </f:entry>
        </f:optionalBlock>
    </f:section>
    <f:section title="${%GitHub Enterprise Servers}">
        <f:entry>
            <f:repeatableProperty field="endpoints">
                <f:entry title="">
                    <div align="right">
                        <f:repeatableDeleteButton/>
                    </div>
                </f:entry>
            </f:repeatableProperty>
        </f:entry>
    </f:section>
</j:jelly>
